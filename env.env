# Required bot token
DISCORD_TOKEN=your_discord_bot_token_here

# Guild targeting
# Optional legacy single-guild default:
GUILD_ID=123456789012345678
# Optional multi-guild allowlist (comma-separated guild IDs):
MANAGED_GUILD_IDS=
# Optional global bot action log channel fallback (per-guild settings can override):
Bot_Log_Channel=123456789012345678

# Web admin listener
WEB_ENABLED=true
WEB_BIND_HOST=0.0.0.0
WEB_PORT=8080
WEB_TLS_ENABLED=true
WEB_TLS_PORT=8081
# Optional custom cert/key pair. If both are empty and WEB_TLS_ENABLED=true, adhoc self-signed TLS is used.
WEB_TLS_CERT_FILE=
WEB_TLS_KEY_FILE=

# Discord behavior
ENABLE_MEMBERS_INTENT=false
ENABLE_MESSAGE_CONTENT_INTENT=false
COMMAND_RESPONSES_EPHEMERAL=false

# Random puppy command
PUPPY_IMAGE_API_URL=https://dog.ceo/api/breeds/image/random
PUPPY_IMAGE_TIMEOUT_SECONDS=8

# Fun commands
FUN_API_TIMEOUT_SECONDS=8
CAT_IMAGE_API_URL=https://api.thecatapi.com/v1/images/search
MEME_API_URL=https://meme-api.com/gimme
DAD_JOKE_API_URL=https://icanhazdadjoke.com/

# URL shortener integration
SHORTENER_ENABLED=true
SHORTENER_BASE_URL=https://l.twy4.us
SHORTENER_TIMEOUT_SECONDS=8

# YouTube notifications
YOUTUBE_NOTIFY_ENABLED=true
YOUTUBE_POLL_INTERVAL_SECONDS=300
YOUTUBE_REQUEST_TIMEOUT_SECONDS=12

# Translation
TRANSLATE_API_URL=https://libretranslate.de/translate
TRANSLATE_API_KEY=
TRANSLATE_TIMEOUT_SECONDS=12

# Wiki help search
WIKI_SEARCH_ENABLED=true
WIKI_SEARCH_URL=
WIKI_SEARCH_TIMEOUT_SECONDS=12

# WordPress and LinkedIn feed integration timeouts
WORDPRESS_REQUEST_TIMEOUT_SECONDS=12
LINKEDIN_REQUEST_TIMEOUT_SECONDS=12

# Spicy Prompts content repo
SPICY_PROMPTS_ENABLED=true
SPICY_PROMPTS_REPO_URL=https://github.com/wickedyoda/SpicyGameAndBookTokQuiz
SPICY_PROMPTS_REPO_BRANCH=main
SPICY_PROMPTS_MANIFEST_PATH=manifests/index.json
SPICY_PROMPTS_REQUEST_TIMEOUT_SECONDS=12
SPICY_PROMPTS_REFRESH_ON_BOOT=true
SPICY_PROMPTS_REFRESH_INTERVAL_HOURS=24

# Member activity backfill (optional)
# MEMBER_ACTIVITY_BACKFILL_SINCE accepts ISO timestamps or YYYY-MM-DD (UTC). Example: 2026-01-01
MEMBER_ACTIVITY_BACKFILL_ENABLED=false
MEMBER_ACTIVITY_BACKFILL_SINCE=
MEMBER_ACTIVITY_BACKFILL_GUILD_ID=
MEMBER_ACTIVITY_BACKFILL_PROGRESS_LOG_INTERVAL=500

# Uptime status integration
UPTIME_STATUS_ENABLED=true
UPTIME_STATUS_PAGE_URL=https://randy.wickedyoda.com/status/everything
UPTIME_STATUS_TIMEOUT_SECONDS=8

# Web auth/session
WEB_ADMIN_DEFAULT_USERNAME=admin@example.com
WEB_ADMIN_DEFAULT_PASSWORD=ChangeMe123!
# Optional alternative to WEB_ADMIN_DEFAULT_PASSWORD:
# WEB_ADMIN_DEFAULT_PASSWORD_HASH=pbkdf2:sha256:600000$...$...
WEB_ADMIN_SESSION_SECRET=replace_this_with_a_random_secret
WEB_SESSION_COOKIE_SECURE=true
WEB_SESSION_COOKIE_SAMESITE=Lax
WEB_SESSION_TIMEOUT_MINUTES=60

# Web hardening and controls
WEB_ENFORCE_CSRF=true
WEB_ENFORCE_SAME_ORIGIN_POSTS=true
WEB_AVATAR_MAX_UPLOAD_BYTES=2097152
WEB_RESTART_ENABLED=false

# Paths/storage
# Host-side storage path used by docker-compose.yml when you run `docker compose --env-file env.env ...`
DATA_DIR=/root/docker/wickedyodabot
# Host-side log path used by docker-compose.yml when you run `docker compose --env-file env.env ...`
LOG_DIR=/root/docker/wickedyodabot/logs
# Inside the container, docker-compose.yml overrides DATA_DIR to /app/data and LOG_DIR to /app/logs.
# Optional explicit SQLite file path. If unset, the bot uses DATA_DIR/mod_actions.db.
# ACTION_DB_PATH=/app/data/mod_actions.db
# Optional env file path for web settings editor:
WEB_ENV_FILE=/app/env.env
# Host path for persisting web GUI env overrides (docker-compose bind mount):
WEB_ENV_FILE_HOST=/root/docker/wickedyodabot/env.env
# Optional external wiki URL button in web GUI:
WEB_GITHUB_WIKI_URL=

# Logging levels
LOG_LEVEL=INFO
CONTAINER_LOG_LEVEL=WARNING
DISCORD_LOG_LEVEL=WARNING
LOG_RETENTION_DAYS=90

# Container timezone (match host). Example: America/Chicago
TZ=America/Chicago
